#!/usr/bin/env bash
# VeriFuse one-command ops wrapper
# Usage: bin/vf COMMAND [args...]
set -euo pipefail

LOCKFILE=/var/lock/verifuse-ingest.lock

# Resolve project root relative to this script
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

case "${1:-}" in
  # ── Core operations ─────────────────────────────────────────────────────────
  migrate)
    python3 verifuse_v2/migrations/run_migrations.py
    ;;

  seed-counties)
    DB_PATH="${VERIFUSE_DB_PATH:-verifuse_v2/data/verifuse_v2.db}"
    python3 verifuse_v2/migrations/run_migrations.py --seed-counties --db "$DB_PATH"
    ;;

  gauntlet)
    python3 -m verifuse_v2.tests.smoke_gauntlet
    ;;

  api-start)
    systemctl start verifuse-api
    ;;

  api-stop)
    systemctl stop verifuse-api
    ;;

  api-restart)
    systemctl restart verifuse-api
    ;;

  logs-api)
    journalctl -u verifuse-api -f
    ;;

  logs-scraper)
    journalctl -u verifuse-scrapers -f
    ;;

  # flock -n: fail immediately if lock held by another process.
  # This prevents timer overlap (when systemd timer fires) AND prevents
  # collision with a concurrent manual run. If locked, prints error and exits 1.
  scraper-run-single)
    shift
    flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --single-case "$@"
    ;;

  scraper-run-window)
    shift
    flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --date-window "$@"
    ;;

  scraper-enum)
    # Sequential case enumerator — bypasses GovSoft search form for historical backfills.
    # Usage: bin/vf scraper-enum --county jefferson --prefix J24 --start-num 1 --end-num 9999
    shift
    flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --sequential-enum "$@"
    ;;

  status)
    systemctl status verifuse-api verifuse-scrapers.timer
    ;;

  backup-db)
    DB_PATH="${VERIFUSE_DB_PATH:-verifuse_v2/data/verifuse_v2.db}"
    BACKUP="${DB_PATH}.bak.$(date +%Y%m%d%H%M%S)"
    sqlite3 "$DB_PATH" ".backup $BACKUP"
    echo "[vf backup-db] Backup written to: $BACKUP"
    ;;

  # ── Optional/convenience ────────────────────────────────────────────────────
  db-shell)
    DB_PATH="${VERIFUSE_DB_PATH:-verifuse_v2/data/verifuse_v2.db}"
    sqlite3 "$DB_PATH"
    ;;

  tail-ingest)
    journalctl -u verifuse-scrapers -f
    ;;

  rebuild-frontend)
    (cd verifuse/site/app && npm ci && npm run build)
    ;;

  # Gate 4 batch extraction — promotes BRONZE leads with html_snapshots to GOLD/SILVER
  # Usage: bin/vf extract-batch [--county jefferson] [--limit 535]
  extract-batch)
    shift
    python3 -c "
import sys, os; sys.path.insert(0, os.getcwd())
from verifuse_v2.ingest.govsoft_extract import run_extraction_batch
county = None; limit = 500
for arg in sys.argv[1:]:
    if arg.startswith('--county='): county = arg.split('=',1)[1]
    elif arg.startswith('--limit='): limit = int(arg.split('=',1)[1])
r = run_extraction_batch(county=county, limit=limit)
print(f'Processed: {r[\"processed\"]} | GOLD: {r[\"gold\"]} | SILVER: {r[\"silver\"]} | BRONZE: {r[\"bronze\"]} | Errors: {r[\"errors\"]}')
for lead in r['leads']:
    print(f'  {lead[\"grade\"]}: {lead[\"id\"]}')
" "$@"
    ;;

  # Pre-sale foreclosure pipeline — scrapes Active/Pending cases from GovSoft
  # Returns upcoming auctions with opening bid + scheduled sale date
  # Covers all 18 active GovSoft counties (adams, arapahoe, archuleta, boulder,
  #   broomfield, douglas, eagle, el_paso, elbert, garfield, gilpin, jefferson,
  #   la_plata, larimer, mesa, san_miguel, teller, weld)
  # Usage: bin/vf pending-sales --county jefferson
  #         bin/vf pending-sales --all-counties
  pending-sales)
    shift
    if [[ "${1:-}" == "--all-counties" ]]; then
      for county in adams arapahoe archuleta boulder broomfield douglas eagle el_paso elbert garfield gilpin jefferson la_plata larimer mesa san_miguel teller weld; do
        echo "[pending-sales] Running county=$county ..."
        flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --pending-sales --county "$county" || true
      done
    else
      flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --pending-sales "$@"
    fi
    ;;

  # pre-sale-scan: alias for pending-sales (plan A5 / C1 naming)
  # Usage: bin/vf pre-sale-scan [--county jefferson] [--all-counties]
  pre-sale-scan)
    shift
    if [[ "${1:-}" == "--all-counties" ]]; then
      for county in adams arapahoe archuleta boulder broomfield douglas eagle el_paso elbert garfield gilpin jefferson la_plata larimer mesa san_miguel teller weld; do
        echo "[pre-sale-scan] Running county=$county ..."
        flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --pending-sales --county "$county" || true
      done
    else
      flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --pending-sales "$@"
    fi
    ;;

  # SALE_INFO backfill — re-scrapes BRONZE leads missing SALE_INFO tab
  # Promotes leads to GOLD/SILVER when overbid is confirmed
  # Usage: bin/vf sale-info-backfill --county jefferson [--limit 50]
  sale-info-backfill)
    shift
    flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --sale-info-backfill "$@"
    ;;

  # Denver County Public Trustee PDF scraper — real auction results + excess funds
  # Data: Current_Sales_Results.pdf (weekly) + excess-funds-list (monthly) from denvergov.org
  # Usage: bin/vf denver-scrape [--dry-run]
  denver-scrape)
    shift
    python3 -m verifuse_v2.scrapers.adapters.denver_scraper "$@"
    ;;

  # Tax lien surplus activation — C.R.S. § 39-11-151
  # Runs weekly (Thursdays 08:00 via systemd timer or manual trigger).
  # Pass --import-csv /path/to/file.csv to ingest county treasurer data.
  tax-lien-run)
    shift
    python3 -m verifuse_v2.scrapers.tax_lien_scraper "$@"
    ;;

  # Assessor owner lookup — populates owner_mailing_address for GOLD/SILVER leads

  assessor-lookup)
    shift
    python3 -m verifuse_v2.scrapers.assessor_lookup "$@"
    ;;

  # enrich-owners: Run assessor lookup for all active counties (limit 20 per county)
  # Usage: bin/vf enrich-owners [--county jefferson] [--limit 20]
  enrich-owners)
    shift
    LIMIT=20
    COUNTY=""
    for arg in "$@"; do
      [[ "$arg" == --limit=* ]] && LIMIT="${arg#--limit=}"
      [[ "$arg" == --county=* ]] && COUNTY="${arg#--county=}"
    done
    if [[ -n "$COUNTY" ]]; then
      echo "[enrich-owners] Running assessor lookup for county=$COUNTY limit=$LIMIT ..."
      python3 -m verifuse_v2.scrapers.assessor_lookup --county "$COUNTY" --limit "$LIMIT"
    else
      for county in jefferson arapahoe adams denver el_paso boulder douglas weld; do
        echo "[enrich-owners] Running assessor lookup for county=$county limit=$LIMIT ..."
        python3 -m verifuse_v2.scrapers.assessor_lookup --county "$county" --limit "$LIMIT" || true
      done
    fi
    ;;

  # unclaimed-seed: Seed sample unclaimed property leads into the pipeline
  # Usage: bin/vf unclaimed-seed [--dry-run]
  unclaimed-seed)
    shift
    DRY_RUN=""
    for arg in "$@"; do [[ "$arg" == "--dry-run" ]] && DRY_RUN="1"; done
    python3 - "$@" <<'PYEOF'
import sys, sqlite3, os, uuid
from datetime import date

dry_run = "--dry-run" in sys.argv
DB = os.environ.get("VERIFUSE_DB_PATH", "verifuse_v2/data/verifuse_v2.db")
conn = sqlite3.connect(DB)
conn.row_factory = sqlite3.Row

SEEDS = [
    ("jefferson", "UP-JEF-2024-001", "DORMANT_BANK", "John T. Morrison", 12450.00, "Commerce City Savings & Loan dormant account", "§ 38-13-101"),
    ("jefferson", "UP-JEF-2024-002", "UNCASHED_CHECK", "Maria L. Gutierrez", 3800.00, "State Farm Insurance uncashed settlement check", "§ 38-13-101"),
    ("arapahoe", "UP-ARP-2024-001", "UTILITY_DEPOSIT", "Robert J. Blackwell", 875.00, "Xcel Energy security deposit refund", "§ 38-13-101"),
    ("arapahoe", "UP-ARP-2024-002", "INSURANCE_PROCEEDS", "Sandra K. Odum", 28600.00, "Life insurance death benefit proceeds", "§ 38-13-101"),
    ("adams", "UP-ADA-2024-001", "DORMANT_BANK", "Carlos A. Mendez", 6700.00, "First Bank of Colorado savings account", "§ 38-13-101"),
    ("adams", "UP-ADA-2024-002", "UNCASHED_CHECK", "Linda R. Thompson", 1250.00, "United Healthcare claims overpayment refund", "§ 38-13-101"),
    ("el_paso", "UP-ELP-2024-001", "DORMANT_BANK", "James W. Patterson", 44200.00, "Wells Fargo investment account (inactive 3+ yrs)", "§ 38-13-101"),
    ("el_paso", "UP-ELP-2024-002", "INSURANCE_PROCEEDS", "Patricia M. Schulz", 18900.00, "Northwestern Mutual whole life policy", "§ 38-13-101"),
    ("el_paso", "UP-ELP-2024-003", "UTILITY_DEPOSIT", "Angela R. Torres", 420.00, "Colorado Springs Utilities deposit refund", "§ 38-13-101"),
    ("denver", "UP-DEN-2024-001", "DORMANT_BANK", "William H. Foster", 89500.00, "US Bank brokerage account (5 years inactive)", "§ 38-13-101"),
    ("denver", "UP-DEN-2024-002", "UNCASHED_CHECK", "Rachel E. Kim", 5100.00, "Anthem BCBS premium refund unclaimed", "§ 38-13-101"),
    ("denver", "UP-DEN-2024-003", "INSURANCE_PROCEEDS", "Michael D. Grant", 62000.00, "Principal Financial Group life insurance", "§ 38-13-101"),
    ("boulder", "UP-BOU-2024-001", "DORMANT_BANK", "Elizabeth A. Murphy", 15700.00, "ColoEast Bankshares checking account", "§ 38-13-101"),
    ("boulder", "UP-BOU-2024-002", "UTILITY_DEPOSIT", "David C. Larson", 310.00, "Excel Energy gas service deposit", "§ 38-13-101"),
    ("larimer", "UP-LAR-2024-001", "DORMANT_BANK", "Nancy J. Caldwell", 9350.00, "Farmers State Bank savings account", "§ 38-13-101"),
    ("larimer", "UP-LAR-2024-002", "INSURANCE_PROCEEDS", "Thomas R. Whitfield", 23100.00, "Allstate auto accident settlement unclaimed", "§ 38-13-101"),
    ("weld", "UP-WEL-2024-001", "UNCASHED_CHECK", "Beverly D. Ingram", 2600.00, "Platte Valley Medical Center refund", "§ 38-13-101"),
    ("weld", "UP-WEL-2024-002", "DORMANT_BANK", "Richard L. Hawkins", 7890.00, "Guarantee Federal Bancshares account", "§ 38-13-101"),
    ("douglas", "UP-DOU-2024-001", "INSURANCE_PROCEEDS", "Catherine S. Wellington", 31500.00, "New York Life policy death benefit", "§ 38-13-101"),
    ("douglas", "UP-DOU-2024-002", "DORMANT_BANK", "Steven P. Harrington", 18300.00, "Park State Bank investment account", "§ 38-13-101"),
]

inserted = 0
skipped = 0
for (county, case_number, subcategory, owner, amount, description, statute) in SEEDS:
    existing = conn.execute("SELECT id FROM leads WHERE case_number=?", [case_number]).fetchone()
    if existing:
        skipped += 1
        continue
    if dry_run:
        print(f"[dry-run] Would insert: {county} {case_number} {owner} ${amount:,.2f}")
        inserted += 1
        continue
    lead_id = str(uuid.uuid4())
    conn.execute("""
        INSERT INTO leads (
            id, county, case_number, data_grade, processing_status,
            surplus_stream, overbid_amount, estimated_surplus, owner_name,
            ned_source, ingestion_source, updated_at
        ) VALUES (?,?,?,'BRONZE','STAGED','UNCLAIMED_PROPERTY',?,?,?,?,
                  'unclaimed_seed',datetime('now'))
    """, [lead_id, county, case_number, amount, amount, owner,
          f"CO Treasury Great Colorado Payback — {subcategory}: {description} ({statute})"])
    inserted += 1

if not dry_run:
    conn.commit()
conn.close()

print(f"unclaimed-seed: {'(dry-run) ' if dry_run else ''}inserted={inserted} skipped={skipped}")
PYEOF
    ;;

  # unclaimed-property-run: Scrape CO State Treasurer for Public Trustee turnovers.
  # Finds overbid funds where the 6-month window expired and PT turned over to State.
  # Statute: C.R.S. § 38-38-111 → § 38-13-101. Fee cap: § 38-13-1304 (HB25-1224, 10%).
  # Usage: bin/vf unclaimed-property-run [--county jefferson] [--all-counties] [--dry-run]
  unclaimed-property-run)
    shift
    flock -n "$LOCKFILE" python3 -m verifuse_v2.scrapers.unclaimed_property_scraper "$@"
    ;;

  # unclaimed-crossref: Print leads with expired restriction windows — candidates for CO Treasurer check.
  # Usage: bin/vf unclaimed-crossref [--county jefferson]
  unclaimed-crossref)
    shift
    python3 -m verifuse_v2.scrapers.unclaimed_property_scraper --build-crossref-list "$@"
    ;;

  # dispatch-alerts: Email GOLD lead alerts to all active subscribed attorneys.
  # Finds GOLD leads promoted in the last 48h (or --hours N).
  # Attorneys with territory locks only receive alerts for their counties.
  # Usage: bin/vf dispatch-alerts [--hours 72] [--dry-run]
  dispatch-alerts)
    shift
    python3 -m verifuse_v2.ingest.alert_dispatcher "$@"
    ;;

  # Promote SILVER → GOLD for leads whose 6-month restriction window has expired.
  # Targets leads with data_grade='SILVER', non-null sale_date, and
  # sale_date + 6 calendar months <= today. Safe to run at any frequency.
  # Usage: bin/vf promote-eligible [--dry-run]
  promote-eligible)
    shift
    DRY_RUN=""
    for arg in "$@"; do [[ "$arg" == "--dry-run" ]] && DRY_RUN="--dry-run"; done
    python3 - $DRY_RUN <<'PYEOF'
import sys, sqlite3
from datetime import date, timedelta
try:
    from dateutil.relativedelta import relativedelta
    DELTA = relativedelta(months=6)
except ImportError:
    DELTA = timedelta(days=182)

dry_run = "--dry-run" in sys.argv
DB = "verifuse_v2/data/verifuse_v2.db"
conn = sqlite3.connect(DB)
conn.row_factory = sqlite3.Row
today = date.today()

candidates = conn.execute(
    "SELECT id, county, case_number, sale_date, overbid_amount, surplus_amount FROM leads "
    "WHERE data_grade='SILVER' AND sale_date IS NOT NULL "
    "AND (overbid_amount > 0 OR surplus_amount > 0)"
).fetchall()

promoted = []
for r in candidates:
    try:
        sale = date.fromisoformat(str(r["sale_date"])[:10])
        eligible = sale + DELTA
        if today >= eligible:
            promoted.append(r)
    except (ValueError, TypeError):
        pass

if not promoted:
    print("promote-eligible: no SILVER leads have expired restriction (nothing to do)")
else:
    print(f"promote-eligible: {len(promoted)} lead(s) eligible for GOLD promotion:")
    for r in promoted:
        sale = date.fromisoformat(str(r["sale_date"])[:10])
        print(f"  {r['county']:12s} {r['case_number']:12s} sale={r['sale_date']} "
              f"overbid=${r['overbid_amount']} restriction_end={sale + DELTA}")
    if dry_run:
        print("(dry-run — no changes made)")
    else:
        ids = [r["id"] for r in promoted]
        ph = ",".join(["?"] * len(ids))
        conn.execute(f"UPDATE leads SET data_grade='GOLD', updated_at=strftime('%s','now') WHERE id IN ({ph})", ids)
        conn.commit()
        print(f"promote-eligible: promoted {len(promoted)} lead(s) to GOLD")
conn.close()
PYEOF
    ;;

  # Gate 4 full county pipeline — Phase 1: counties with SALE_INFO captured;
  # Phase 2: counties needing SALE_INFO backfill first (Jefferson/Boulder/Broomfield)
  # Usage: bin/vf gate4-run-all
  gate4-run-all)
    shift
    echo "=== Phase 1: Gate 4 extraction on counties with SALE_INFO captured ==="
    for county in adams weld douglas denver gilpin arapahoe; do
      echo "--- Gate 4: $county ---"
      python3 -c "
import sys, os; sys.path.insert(0, os.getcwd())
from verifuse_v2.ingest.govsoft_extract import run_extraction_batch
results = run_extraction_batch('$county', limit=300)
print(results)
"
    done

    echo "=== Phase 2: SALE_INFO backfill + Gate 4 for counties with missing snapshots ==="
    for county in jefferson boulder broomfield; do
      echo "--- SALE_INFO backfill: $county ---"
      flock -n /tmp/vf_ingest.lock python3 -m verifuse_v2.ingest.ingest_runner --sale-info-backfill --county "$county" --limit 600 || echo "WARN: could not acquire lock for $county"
      echo "--- Gate 4: $county ---"
      python3 -c "
import sys, os; sys.path.insert(0, os.getcwd())
from verifuse_v2.ingest.govsoft_extract import run_extraction_batch
results = run_extraction_batch('$county', limit=600)
print(results)
"
    done

    echo "=== Gate 4 Run Complete ==="
    python3 -c "
import sqlite3, os
conn = sqlite3.connect(os.environ['VERIFUSE_DB_PATH'])
for row in conn.execute('SELECT county, data_grade, COUNT(*) FROM leads GROUP BY county, data_grade ORDER BY county, data_grade'):
    print(row)
conn.close()
"
    ;;

  # Coverage report — print all county_profiles with status and lead counts
  # Usage: bin/vf coverage-report
  coverage-report)
    python3 - <<'PYEOF'
import sqlite3, os
DB = os.environ.get("VERIFUSE_DB_PATH", "verifuse_v2/data/verifuse_v2.db")
conn = sqlite3.connect(DB)
conn.row_factory = sqlite3.Row
rows = conn.execute("""
    SELECT cp.county, cp.platform_type, cp.access_method,
           COUNT(CASE WHEN l.data_grade='GOLD' THEN 1 END) as gold,
           COUNT(CASE WHEN l.data_grade='SILVER' THEN 1 END) as silver,
           COUNT(CASE WHEN l.data_grade='BRONZE' THEN 1 END) as bronze,
           COUNT(l.id) as total
    FROM county_profiles cp
    LEFT JOIN leads l ON l.county = cp.county
    GROUP BY cp.county ORDER BY cp.county
""").fetchall()
print(f"{'COUNTY':<20} {'PLATFORM':<12} {'ACCESS':<12} {'GOLD':>4} {'SILVER':>6} {'BRONZE':>6} {'TOTAL':>6}")
print("-" * 75)
for r in rows:
    print(f"{r['county']:<20} {r['platform_type'] or 'unknown':<12} {r['access_method'] or 'unknown':<12} {r['gold']:>4} {r['silver']:>6} {r['bronze']:>6} {r['total']:>6}")
print(f"\nTotal counties: {len(rows)} | Active coverage: {sum(1 for r in rows if r['gold'] > 0 or r['silver'] > 0)}")
conn.close()
PYEOF
    ;;

  # PDF intake — submit a PDF file for a paper-only county
  # Usage: bin/vf pdf-intake [county] [pdf_path] [case_number] [overbid_amount]
  pdf-intake)
    shift
    COUNTY="${1:-}"
    PDF_PATH="${2:-}"
    CASE_NUMBER="${3:-}"
    OVERBID="${4:-}"
    if [[ -z "$COUNTY" || -z "$PDF_PATH" || -z "$CASE_NUMBER" ]]; then
      echo "Usage: vf pdf-intake COUNTY PDF_PATH CASE_NUMBER [OVERBID_AMOUNT]"
      exit 1
    fi
    BASE_URL="${VERIFUSE_API_URL:-http://localhost:8000}"
    curl -s -X POST "${BASE_URL}/api/intake/pdf-upload" \
      -F "file=@${PDF_PATH}" \
      -F "county=${COUNTY}" \
      -F "case_number=${CASE_NUMBER}" \
      $([ -n "$OVERBID" ] && echo "-F overbid_amount=${OVERBID}") \
      | python3 -m json.tool
    ;;

  # Research county — try common URL patterns to identify platform
  # Usage: bin/vf research-county COUNTY_SLUG
  research-county)
    shift
    COUNTY="${1:-}"
    if [[ -z "$COUNTY" ]]; then
      echo "Usage: vf research-county COUNTY_SLUG (e.g. montrose, pueblo)"
      exit 1
    fi
    echo "[research-county] Probing $COUNTY for known platform patterns..."
    # Try common GovSoft/GTSData patterns
    for URL in \
      "https://foreclosures.${COUNTY}gov.org/" \
      "https://foreclosures.${COUNTY}co.us/" \
      "https://public.${COUNTY}co.us/foreclosures/" \
      "https://${COUNTY}.gtsdata.com/" \
      "https://foreclosure.${COUNTY}county.org/"; do
      STATUS=$(curl -s -o /dev/null -w "%{http_code}" --max-time 8 "$URL" 2>/dev/null || echo "ERR")
      echo "  [$STATUS] $URL"
    done
    ;;

  # Scraper run for a specific county (date-window alias)
  # Usage: bin/vf scraper-run COUNTY [--days N]
  scraper-run)
    shift
    COUNTY="${1:-}"
    if [[ -z "$COUNTY" ]]; then
      echo "Usage: vf scraper-run COUNTY [--days N]"
      exit 1
    fi
    shift
    flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --date-window --county "$COUNTY" "$@"
    ;;

  # promote-presale: Scan existing leads with future sale_date → PRE_SALE status
  # No Playwright required — pure DB operation. Run any time.
  # Usage: bin/vf promote-presale [--county jefferson] [--dry-run]
  promote-presale)
    shift
    COUNTY_ARG=""
    DRY_RUN=""
    for arg in "$@"; do
      [[ "$arg" == "--dry-run" ]] && DRY_RUN="1"
      [[ "$arg" == --county=* ]] && COUNTY_ARG="${arg#--county=}"
      [[ "$arg" == "--county" ]] && next=1
      [[ "${next:-}" == "1" ]] && COUNTY_ARG="$arg" && next=""
    done
    python3 - "$@" <<'PYEOF'
import sys, sqlite3, os
from datetime import date

dry_run = "--dry-run" in sys.argv
county_filter = None
args = sys.argv[1:]
for i, a in enumerate(args):
    if a == "--county" and i+1 < len(args):
        county_filter = args[i+1]
    elif a.startswith("--county="):
        county_filter = a.split("=",1)[1]

DB = os.environ.get("VERIFUSE_DB_PATH", "verifuse_v2/data/verifuse_v2.db")
conn = sqlite3.connect(DB)
conn.row_factory = sqlite3.Row

where = ""
params = []
if county_filter:
    where = " AND county = ?"
    params.append(county_filter)

# Count candidates first
candidates = conn.execute(f"""
    SELECT id, county, case_number, sale_date, scheduled_sale_date
    FROM leads
    WHERE processing_status != 'PRE_SALE'
      AND data_grade NOT IN ('GOLD','SILVER')
      AND (
          (scheduled_sale_date IS NOT NULL AND scheduled_sale_date > date('now'))
          OR (sale_date IS NOT NULL AND sale_date > date('now'))
      ){where}
""", params).fetchall()

print(f"promote-presale: {len(candidates)} candidates found" + (f" (county={county_filter})" if county_filter else ""))
for r in candidates[:20]:
    print(f"  {r['county']:12s} {(r['case_number'] or '')[:15]:15s} sale={r['sale_date']} sched={r['scheduled_sale_date']}")
if len(candidates) > 20:
    print(f"  ... and {len(candidates)-20} more")

if dry_run:
    print("(dry-run — no changes made)")
else:
    if candidates:
        conn.execute(f"""
            UPDATE leads SET
                processing_status = 'PRE_SALE',
                ned_source = COALESCE(ned_source, 'date_window_future'),
                updated_at = datetime('now')
            WHERE processing_status != 'PRE_SALE'
              AND data_grade NOT IN ('GOLD','SILVER')
              AND (
                  (scheduled_sale_date IS NOT NULL AND scheduled_sale_date > date('now'))
                  OR (sale_date IS NOT NULL AND sale_date > date('now'))
              ){where}
        """, params)
        conn.commit()
        print(f"promote-presale: {len(candidates)} leads set to PRE_SALE")

        total = conn.execute("SELECT COUNT(*) FROM leads WHERE processing_status='PRE_SALE'").fetchone()[0]
        print(f"promote-presale: total PRE_SALE leads = {total}")
    else:
        print("promote-presale: nothing to do")
conn.close()
PYEOF
    ;;

  # tax-deed-seed: Seed sample tax deed surplus leads (C.R.S. § 39-12-111)
  # Usage: bin/vf tax-deed-seed [--dry-run]
  tax-deed-seed)
    shift
    DRY_RUN=""
    for arg in "$@"; do [[ "$arg" == "--dry-run" ]] && DRY_RUN="1"; done
    python3 - "$@" <<'PYEOF'
import sys, sqlite3, os, uuid

dry_run = "--dry-run" in sys.argv
DB = os.environ.get("VERIFUSE_DB_PATH", "verifuse_v2/data/verifuse_v2.db")
conn = sqlite3.connect(DB)
conn.row_factory = sqlite3.Row

TAX_DEED_SEEDS = [
    ("jefferson", "TD-JEF-2024-001", "Robert A. Nkosi", 34200.00, "2024-03-15", "Tax deed sale surplus — property sold for $184,200 vs $150,000 taxes/fees owed", "Jeffco Treasurer"),
    ("jefferson", "TD-JEF-2024-002", "Maria C. Delgado", 18700.00, "2024-05-22", "Tax deed surplus — sale exceeded outstanding tax obligation", "Jeffco Treasurer"),
    ("arapahoe", "TD-ARP-2024-001", "George T. Williams", 52100.00, "2024-02-08", "Tax deed auction surplus — buyer paid $302,100 vs $250,000 delinquent taxes", "Arapahoe County Treasurer"),
    ("arapahoe", "TD-ARP-2024-002", "Susan L. Mitchell", 11400.00, "2024-06-14", "Tax deed sale proceeds exceed lien amount — surplus held by county", "Arapahoe County Treasurer"),
    ("adams", "TD-ADA-2024-001", "Patrick E. Sullivan", 23800.00, "2024-01-30", "Adams County tax deed surplus — commercial property auction", "Adams County Treasurer"),
    ("el_paso", "TD-ELP-2024-001", "Jennifer M. Kowalski", 67500.00, "2024-04-10", "El Paso tax deed sale — residential property surplus funds", "EPCO Treasurer"),
    ("el_paso", "TD-ELP-2024-002", "Harold D. Simmons", 8900.00, "2024-07-19", "Tax deed auction surplus held per § 39-12-111", "EPCO Treasurer"),
    ("larimer", "TD-LAR-2024-001", "Christine B. Anderson", 29300.00, "2024-03-01", "Larimer County tax deed surplus — buyer overbid exceeds tax obligation", "Larimer County Treasurer"),
    ("weld", "TD-WEL-2024-001", "Anthony R. Pierce", 41200.00, "2024-05-05", "Weld County tax deed surplus — agricultural parcel auction", "Weld County Treasurer"),
    ("boulder", "TD-BOU-2024-001", "Deborah K. Chen", 88700.00, "2024-02-20", "Boulder County tax deed surplus — high-value residential property", "Boulder County Treasurer"),
    ("douglas", "TD-DOU-2024-001", "Marcus J. Olsen", 156300.00, "2024-06-01", "Douglas County tax deed surplus — luxury residential property auction", "Douglas County Treasurer"),
    ("douglas", "TD-DOU-2024-002", "Victoria L. Pham", 33100.00, "2024-08-12", "Douglas County tax deed surplus — townhome auction proceeds", "Douglas County Treasurer"),
    ("mesa", "TD-MES-2024-001", "Frank W. Bauer", 19600.00, "2024-04-25", "Mesa County tax deed surplus — commercial lot auction", "Mesa County Treasurer"),
    ("teller", "TD-TEL-2024-001", "Gloria N. Washington", 27800.00, "2024-03-18", "Teller County tax deed surplus — mountain cabin property", "Teller County Treasurer"),
    ("garfield", "TD-GAR-2024-001", "Steven C. Hendricks", 45000.00, "2024-07-03", "Garfield County tax deed surplus — rural parcel with mineral rights", "Garfield County Treasurer"),
]

inserted = 0
skipped = 0
for (county, case_number, owner, amount, sale_date, description, source) in TAX_DEED_SEEDS:
    existing = conn.execute("SELECT id FROM leads WHERE case_number=?", [case_number]).fetchone()
    if existing:
        skipped += 1
        continue
    if dry_run:
        print(f"[dry-run] Would insert: {county} {case_number} {owner} ${amount:,.2f} sale={sale_date}")
        inserted += 1
        continue
    lead_id = str(uuid.uuid4())
    conn.execute("""
        INSERT INTO leads (
            id, county, case_number, data_grade, processing_status,
            surplus_stream, overbid_amount, estimated_surplus, owner_name,
            sale_date, ned_source, ingestion_source, updated_at
        ) VALUES (?,?,?,'BRONZE','STAGED','TAX_DEED_SURPLUS',?,?,?,?,?,
                  'tax_deed_seed',datetime('now'))
    """, [lead_id, county, case_number, amount, amount, owner,
          sale_date, f"C.R.S. § 39-12-111 — {description}. Source: {source}"])
    inserted += 1

if not dry_run:
    conn.commit()
conn.close()

print(f"tax-deed-seed: {'(dry-run) ' if dry_run else ''}inserted={inserted} skipped={skipped}")
PYEOF
    ;;

  # ops-jobs: list recent admin ops center jobs
  # Usage: bin/vf ops-jobs [--limit 20]
  ops-jobs)
    shift
    LIMIT="${1:-20}"
    DB_PATH="${VERIFUSE_DB_PATH:-verifuse_v2/data/verifuse_v2.db}"
    sqlite3 "$DB_PATH" -column -header "
      SELECT substr(id,1,8)||'...' as id,
             command,
             COALESCE(county,'—') as county,
             status,
             datetime(triggered_at,'unixepoch') as triggered,
             CASE WHEN finished_at AND started_at THEN (finished_at-started_at)||'s' ELSE '—' END as duration,
             exit_code
      FROM ops_jobs
      ORDER BY triggered_at DESC
      LIMIT ${LIMIT};
    "
    ;;

  deploy)
    echo "[vf deploy] Gate 9 deployment sequence. Run each step manually and verify:"
    echo ""
    echo "  1. vf backup-db"
    echo "  2. vf migrate"
    echo "  3. vf api-restart"
    echo "  4. systemctl enable --now verifuse-scrapers.timer"
    echo "  5. vf gauntlet       # must be >= 60 PASS"
    echo "  6. vf rebuild-frontend"
    echo ""
    echo "Manual approval required before each step. See docs/RUNBOOK.md."
    ;;

  # evidence-audit: Lists all ATTORNEY_READY/GOLD leads with zero evidence → flags for backfill
  # Usage: bin/vf evidence-audit [--county jefferson]
  evidence-audit)
    shift
    COUNTY_FILTER=""
    for arg in "$@"; do
      [[ "$arg" == --county=* ]] && COUNTY_FILTER="${arg#--county=}"
    done
    python3 - "$@" <<'PYEOF'
import sys, sqlite3, os

COUNTY = None
for arg in sys.argv[1:]:
    if arg.startswith("--county="):
        COUNTY = arg.split("=", 1)[1]
    elif arg == "--county" and sys.argv.index(arg) + 1 < len(sys.argv):
        COUNTY = sys.argv[sys.argv.index(arg) + 1]

DB = os.environ.get("VERIFUSE_DB_PATH", "verifuse_v2/data/verifuse_v2.db")
conn = sqlite3.connect(DB)
conn.row_factory = sqlite3.Row

where = "WHERE l.data_grade IN ('GOLD') AND l.processing_status != 'REJECT'"
params = []
if COUNTY:
    where += " AND l.county = ?"
    params.append(COUNTY)

rows = conn.execute(f"""
    SELECT l.id, l.county, l.case_number, l.data_grade, l.processing_status,
           (SELECT COUNT(*) FROM evidence_documents ed WHERE ed.asset_id = 'FORECLOSURE:CO:' || UPPER(l.county) || ':' || l.case_number) as pdf_ct,
           (SELECT COUNT(*) FROM html_snapshots hs
            WHERE hs.asset_id = 'FORECLOSURE:CO:' || UPPER(l.county) || ':' || UPPER(l.case_number)) as snap_ct
    FROM leads l
    {where}
    ORDER BY l.county, l.case_number
""", params).fetchall()

flagged = 0
for r in rows:
    total_evidence = (r["pdf_ct"] or 0) + (r["snap_ct"] or 0)
    if total_evidence == 0:
        print(f"[NO EVIDENCE] {r['county']:15s} {r['case_number']:20s} {r['data_grade']:8s} {r['processing_status']}")
        flagged += 1

conn.close()
print(f"\nevidence-audit: {flagged} GOLD leads with zero evidence (county={COUNTY or 'ALL'})")
if flagged > 0:
    print("Remediation: bin/vf gate4-run-all OR bin/vf sale-info-backfill --county <county>")
PYEOF
    ;;

  # record-outcome: Record attorney case filing outcome into case_outcomes table.
  # Usage: bin/vf record-outcome --case-id J2500134 --result won --amount 45000 --days 87
  #        bin/vf record-outcome --case-id C123 --result settled --amount 32000 --county jefferson
  record-outcome)
    shift
    python3 - "$@" <<'PYEOF'
import sys, sqlite3, os, uuid
from datetime import datetime, timezone

CASE_ID = None; RESULT = None; AMOUNT = None; DAYS = None; COUNTY = None

args = sys.argv[1:]
i = 0
while i < len(args):
    if args[i] == "--case-id" and i+1 < len(args):
        CASE_ID = args[i+1]; i += 2
    elif args[i] == "--result" and i+1 < len(args):
        RESULT = args[i+1]; i += 2
    elif args[i] == "--amount" and i+1 < len(args):
        try: AMOUNT = int(float(args[i+1]) * 100)
        except: pass
        i += 2
    elif args[i] == "--days" and i+1 < len(args):
        try: DAYS = int(args[i+1])
        except: pass
        i += 2
    elif args[i] == "--county" and i+1 < len(args):
        COUNTY = args[i+1]; i += 2
    else:
        i += 1

VALID = ("won","settled","dismissed","pending","withdrawn")
if not CASE_ID:
    print("ERROR: --case-id required"); sys.exit(1)
if not RESULT or RESULT not in VALID:
    print(f"ERROR: --result required, must be one of {VALID}"); sys.exit(1)

DB = os.environ.get("VERIFUSE_DB_PATH", "verifuse_v2/data/verifuse_v2.db")
conn = sqlite3.connect(DB)

# Ensure case_outcomes table exists
conn.execute("""
CREATE TABLE IF NOT EXISTS case_outcomes (
    id TEXT PRIMARY KEY DEFAULT (lower(hex(randomblob(16)))),
    case_id TEXT,
    attorney_id TEXT,
    filing_date TEXT,
    hearing_date TEXT,
    result TEXT CHECK(result IN ('won','settled','dismissed','pending','withdrawn')),
    amount_recovered_cents INTEGER,
    time_to_recovery_days INTEGER,
    judge_name TEXT,
    county TEXT,
    notes TEXT,
    recorded_at TEXT DEFAULT (datetime('now')),
    recorded_by TEXT
)
""")

outcome_id = str(uuid.uuid4())
conn.execute("""
INSERT INTO case_outcomes (id, case_id, result, amount_recovered_cents, time_to_recovery_days, county, recorded_by)
VALUES (?, ?, ?, ?, ?, ?, 'bin/vf record-outcome')
""", [outcome_id, CASE_ID, RESULT, AMOUNT, DAYS, COUNTY])
conn.commit()
conn.close()

amount_str = f"${AMOUNT/100:,.2f}" if AMOUNT else "unspecified"
days_str = f"{DAYS} days" if DAYS else "unspecified"
print(f"[record-outcome] Recorded: case={CASE_ID} result={RESULT} amount={amount_str} days={days_str} county={COUNTY or 'unspecified'}")
print(f"  outcome_id={outcome_id}")
PYEOF
    ;;

  # verify-sota: Run SOTA triple-verification on a single GOLD lead
  # Usage: bin/vf verify-sota --asset-id FORECLOSURE:CO:ARAPAHOE:0148-2023
  # Usage: bin/vf verify-sota --all-gold          (batch all active GOLD leads)
  verify-sota)
    shift
    ASSET_ID=""
    ALL_GOLD=0
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --asset-id) ASSET_ID="$2"; shift 2 ;;
        --all-gold) ALL_GOLD=1; shift ;;
        *) shift ;;
      esac
    done
    python3 - "$ASSET_ID" "$ALL_GOLD" << 'PYEOF'
import sys, os, sqlite3
from decimal import Decimal

asset_id = sys.argv[1]
all_gold = sys.argv[2] == "1"

db_path = os.environ.get("VERIFUSE_DB_PATH", "verifuse_v2/data/verifuse_v2.db")
conn = sqlite3.connect(db_path, timeout=30)
conn.row_factory = sqlite3.Row
conn.execute("PRAGMA journal_mode=WAL")

from verifuse_v2.core.ai_verification_engine import VerificationEngine
engine = VerificationEngine(use_docai=True, use_gemini=True, use_claude=False)

if all_gold == "0" and asset_id:
    row = conn.execute(
        "SELECT overbid_amount FROM leads WHERE id=? OR 'FORECLOSURE:CO:'||UPPER(county)||':'||case_number=?",
        [asset_id, asset_id]
    ).fetchone()
    overbid = Decimal(str(row["overbid_amount"] or 0)) if row else Decimal("0")
    result = engine.verify_from_vault(asset_id, overbid, conn)
    print(f"\nASSET: {result.asset_id}")
    print(f"TIER:  {result.tier}  (confidence: {result.confidence:.0%})")
    print(f"NOTES: {result.verification_notes}")
    if result.errors: print(f"ERRORS: {result.errors}")
    print(f"TIME:  {result.duration_ms}ms\n")
else:
    # Batch all active GOLD leads
    rows = conn.execute("""
        SELECT 'FORECLOSURE:CO:'||UPPER(county)||':'||case_number as asset_id,
               overbid_amount
        FROM leads WHERE data_grade='GOLD' AND overbid_amount > 0
        AND (claim_deadline IS NULL OR claim_deadline >= date('now'))
        ORDER BY overbid_amount DESC
    """).fetchall()
    print(f"\nRunning SOTA verification on {len(rows)} GOLD leads...\n")
    triple = ai_ver = html_only = disputed = 0
    for r in rows:
        try:
            result = engine.verify_from_vault(r["asset_id"], Decimal(str(r["overbid_amount"])), conn)
            if result.tier == "TRIPLE_VERIFIED": triple += 1
            elif result.tier == "AI_VERIFIED": ai_ver += 1
            elif result.tier == "DISPUTED": disputed += 1
            else: html_only += 1
            print(f"  {r['asset_id']}: {result.tier} ({result.confidence:.0%})")
        except Exception as e:
            print(f"  {r['asset_id']}: ERROR — {e}")
            html_only += 1
    print(f"\n{'='*50}")
    print(f"TRIPLE_VERIFIED: {triple}  AI_VERIFIED: {ai_ver}  HTML_MATH: {html_only}  DISPUTED: {disputed}")
    print(f"{'='*50}\n")

conn.close()
PYEOF
    ;;

  *)
    cat <<'USAGE'
VeriFuse one-command ops wrapper

Usage: vf COMMAND [args...]

Required commands:
  migrate                 Run all DB migrations (idempotent)
  seed-counties           Seed county_profiles from counties.yaml (INSERT OR IGNORE)
  gauntlet                Run full smoke gauntlet (target: >= 60 PASS)
  api-start               Start verifuse-api systemd unit
  api-stop                Stop verifuse-api systemd unit
  api-restart             Restart verifuse-api (apply API changes)
  logs-api                Tail API logs (journalctl -f)
  logs-scraper            Tail scraper logs (journalctl -f)
  scraper-run-single      Run single-case ingest (flock; pass --county --case-number)
  scraper-run-window      Run date-window ingest (flock; pass --county --days N)
  scraper-enum            Sequential case enumerator (flock; --county --prefix --start-num --end-num)
  extract-batch           Gate 4 batch extraction on BRONZE leads (--county --limit)
  gate4-run-all           Full Gate 4 pipeline: Phase 1 (adams/weld/douglas/gilpin/arapahoe/denver) + Phase 2 (jefferson/boulder/broomfield with SALE_INFO backfill)
  pending-sales           Scrape Active/Pending pre-sale cases (--county or --all-counties; 18 active counties)
  pre-sale-scan           Alias for pending-sales (--county or --all-counties; 18 active counties)
  sale-info-backfill      Re-scrape BRONZE leads missing SALE_INFO (--county --limit)
  denver-scrape           Denver Public Trustee PDF scraper (--dry-run to preview)
  promote-eligible        Promote SILVER → GOLD when 6-month restriction expires (--dry-run)
  promote-presale         Scan existing leads with future sale_date → PRE_SALE status (--dry-run, --county)
  ops-jobs                List recent Admin Ops Center job runs
  status                  Show API + scraper timer systemd status
  backup-db               SQLite online backup (timestamped .bak file)

Optional commands:
  db-shell                Open SQLite shell on the DB
  tail-ingest             Alias for logs-scraper
  rebuild-frontend        npm ci + npm run build in verifuse/site/app
  deploy                  Print Gate 9 deploy checklist (manual confirmation required)
  coverage-report         Print all 64 counties with status and lead counts
  pdf-intake              Submit a PDF for paper-only county (COUNTY PDF_PATH CASE_NUMBER [OVERBID])
  research-county         Probe URL patterns to identify county platform (COUNTY_SLUG)
  scraper-run             Run date-window scraper for a specific county
  enrich-owners           Run assessor owner/address lookup for all supported counties (--county --limit)
  unclaimed-seed          Seed 20 sample Colorado unclaimed property leads (C.R.S. § 38-13-101)
  unclaimed-property-run  Scrape CO State Treasurer for Public Trustee unclaimed foreclosure surplus (§ 38-13-101)
  unclaimed-crossref      List expired-window leads that are candidates for CO Treasurer unclaimed property check
  tax-deed-seed           Seed 15 sample tax deed surplus leads (C.R.S. § 39-12-111)
  evidence-audit          List GOLD leads with zero evidence → flag for backfill (--county optional)
  record-outcome          Record attorney case outcome into case_outcomes (--case-id --result --amount --days)
  verify-sota             SOTA triple-verification on a GOLD lead (--asset-id ID | --all-gold)

Examples:
  vf migrate
  vf gauntlet
  vf scraper-run-single --county jefferson --case-number J2400300
  vf scraper-run-window --county jefferson --days 3
  vf backup-db && vf migrate && vf api-restart && vf gauntlet
USAGE
    exit 1
    ;;
esac
