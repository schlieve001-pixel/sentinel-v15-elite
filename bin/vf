#!/usr/bin/env bash
# VeriFuse one-command ops wrapper
# Usage: bin/vf COMMAND [args...]
set -euo pipefail

LOCKFILE=/var/lock/verifuse-ingest.lock

# Resolve project root relative to this script
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

case "${1:-}" in
  # ── Core operations ─────────────────────────────────────────────────────────
  migrate)
    python3 verifuse_v2/migrations/run_migrations.py
    ;;

  seed-counties)
    DB_PATH="${VERIFUSE_DB_PATH:-verifuse_v2/data/verifuse_v2.db}"
    python3 verifuse_v2/migrations/run_migrations.py --seed-counties --db "$DB_PATH"
    ;;

  gauntlet)
    python3 -m verifuse_v2.tests.smoke_gauntlet
    ;;

  api-start)
    systemctl start verifuse-api
    ;;

  api-stop)
    systemctl stop verifuse-api
    ;;

  api-restart)
    systemctl restart verifuse-api
    ;;

  logs-api)
    journalctl -u verifuse-api -f
    ;;

  logs-scraper)
    journalctl -u verifuse-scrapers -f
    ;;

  # flock -n: fail immediately if lock held by another process.
  # This prevents timer overlap (when systemd timer fires) AND prevents
  # collision with a concurrent manual run. If locked, prints error and exits 1.
  scraper-run-single)
    shift
    flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --single-case "$@"
    ;;

  scraper-run-window)
    shift
    flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --date-window "$@"
    ;;

  scraper-enum)
    # Sequential case enumerator — bypasses GovSoft search form for historical backfills.
    # Usage: bin/vf scraper-enum --county jefferson --prefix J24 --start-num 1 --end-num 9999
    shift
    flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --sequential-enum "$@"
    ;;

  status)
    systemctl status verifuse-api verifuse-scrapers.timer
    ;;

  backup-db)
    DB_PATH="${VERIFUSE_DB_PATH:-verifuse_v2/data/verifuse_v2.db}"
    BACKUP="${DB_PATH}.bak.$(date +%Y%m%d%H%M%S)"
    sqlite3 "$DB_PATH" ".backup $BACKUP"
    echo "[vf backup-db] Backup written to: $BACKUP"
    ;;

  # ── Optional/convenience ────────────────────────────────────────────────────
  db-shell)
    DB_PATH="${VERIFUSE_DB_PATH:-verifuse_v2/data/verifuse_v2.db}"
    sqlite3 "$DB_PATH"
    ;;

  tail-ingest)
    journalctl -u verifuse-scrapers -f
    ;;

  rebuild-frontend)
    (cd verifuse/site/app && npm ci && npm run build)
    ;;

  # Gate 4 batch extraction — promotes BRONZE leads with html_snapshots to GOLD/SILVER
  # Usage: bin/vf extract-batch [--county jefferson] [--limit 535]
  extract-batch)
    shift
    python3 -c "
import sys, os; sys.path.insert(0, os.getcwd())
from verifuse_v2.ingest.govsoft_extract import run_extraction_batch
county = None; limit = 500
for arg in sys.argv[1:]:
    if arg.startswith('--county='): county = arg.split('=',1)[1]
    elif arg.startswith('--limit='): limit = int(arg.split('=',1)[1])
r = run_extraction_batch(county=county, limit=limit)
print(f'Processed: {r[\"processed\"]} | GOLD: {r[\"gold\"]} | SILVER: {r[\"silver\"]} | BRONZE: {r[\"bronze\"]} | Errors: {r[\"errors\"]}')
for lead in r['leads']:
    print(f'  {lead[\"grade\"]}: {lead[\"id\"]}')
" "$@"
    ;;

  # Pre-sale foreclosure pipeline — scrapes Active/Pending cases from GovSoft
  # Returns upcoming auctions with opening bid + scheduled sale date
  # Covers all 12 GovSoft counties: adams, arapahoe, boulder, broomfield, douglas,
  #   eagle, el_paso, gilpin, jefferson, larimer, mesa, weld
  # Usage: bin/vf pending-sales --county jefferson
  #         bin/vf pending-sales --all-counties
  pending-sales)
    shift
    if [[ "${1:-}" == "--all-counties" ]]; then
      for county in adams arapahoe boulder broomfield douglas eagle el_paso gilpin jefferson larimer mesa weld; do
        echo "[pending-sales] Running county=$county ..."
        flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --pending-sales --county "$county" || true
      done
    else
      flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --pending-sales "$@"
    fi
    ;;

  # SALE_INFO backfill — re-scrapes BRONZE leads missing SALE_INFO tab
  # Promotes leads to GOLD/SILVER when overbid is confirmed
  # Usage: bin/vf sale-info-backfill --county jefferson [--limit 50]
  sale-info-backfill)
    shift
    flock -n "$LOCKFILE" python3 -m verifuse_v2.ingest.ingest_runner --sale-info-backfill "$@"
    ;;

  # Denver County Public Trustee PDF scraper — real auction results + excess funds
  # Data: Current_Sales_Results.pdf (weekly) + excess-funds-list (monthly) from denvergov.org
  # Usage: bin/vf denver-scrape [--dry-run]
  denver-scrape)
    shift
    python3 -m verifuse_v2.scrapers.adapters.denver_scraper "$@"
    ;;

  # Tax lien surplus activation — C.R.S. § 39-11-151
  # Runs weekly (Thursdays 08:00 via systemd timer or manual trigger).
  # Pass --import-csv /path/to/file.csv to ingest county treasurer data.
  tax-lien-run)
    shift
    python3 -m verifuse_v2.scrapers.tax_lien_scraper "$@"
    ;;

  # Assessor owner lookup — populates owner_mailing_address for GOLD/SILVER leads

  assessor-lookup)
    shift
    python3 -m verifuse_v2.scrapers.assessor_lookup "$@"
    ;;

  # Promote SILVER → GOLD for leads whose 6-month restriction window has expired.
  # Targets leads with data_grade='SILVER', non-null sale_date, and
  # sale_date + 6 calendar months <= today. Safe to run at any frequency.
  # Usage: bin/vf promote-eligible [--dry-run]
  promote-eligible)
    shift
    DRY_RUN=""
    for arg in "$@"; do [[ "$arg" == "--dry-run" ]] && DRY_RUN="--dry-run"; done
    python3 - $DRY_RUN <<'PYEOF'
import sys, sqlite3
from datetime import date, timedelta
try:
    from dateutil.relativedelta import relativedelta
    DELTA = relativedelta(months=6)
except ImportError:
    DELTA = timedelta(days=182)

dry_run = "--dry-run" in sys.argv
DB = "verifuse_v2/data/verifuse_v2.db"
conn = sqlite3.connect(DB)
conn.row_factory = sqlite3.Row
today = date.today()

candidates = conn.execute(
    "SELECT id, county, case_number, sale_date, overbid_amount FROM leads "
    "WHERE data_grade='SILVER' AND sale_date IS NOT NULL"
).fetchall()

promoted = []
for r in candidates:
    try:
        sale = date.fromisoformat(str(r["sale_date"])[:10])
        eligible = sale + DELTA
        if today >= eligible:
            promoted.append(r)
    except (ValueError, TypeError):
        pass

if not promoted:
    print("promote-eligible: no SILVER leads have expired restriction (nothing to do)")
else:
    print(f"promote-eligible: {len(promoted)} lead(s) eligible for GOLD promotion:")
    for r in promoted:
        sale = date.fromisoformat(str(r["sale_date"])[:10])
        print(f"  {r['county']:12s} {r['case_number']:12s} sale={r['sale_date']} "
              f"overbid=${r['overbid_amount']} restriction_end={sale + DELTA}")
    if dry_run:
        print("(dry-run — no changes made)")
    else:
        ids = [r["id"] for r in promoted]
        ph = ",".join(["?"] * len(ids))
        conn.execute(f"UPDATE leads SET data_grade='GOLD', updated_at=strftime('%s','now') WHERE id IN ({ph})", ids)
        conn.commit()
        print(f"promote-eligible: promoted {len(promoted)} lead(s) to GOLD")
conn.close()
PYEOF
    ;;

  # Gate 4 full county pipeline — Phase 1: counties with SALE_INFO captured;
  # Phase 2: counties needing SALE_INFO backfill first (Jefferson/Boulder/Broomfield)
  # Usage: bin/vf gate4-run-all
  gate4-run-all)
    shift
    echo "=== Phase 1: Gate 4 extraction on counties with SALE_INFO captured ==="
    for county in adams weld douglas denver gilpin arapahoe; do
      echo "--- Gate 4: $county ---"
      python3 -c "
import sys, os; sys.path.insert(0, os.getcwd())
from verifuse_v2.ingest.govsoft_extract import run_extraction_batch
results = run_extraction_batch('$county', limit=300)
print(results)
"
    done

    echo "=== Phase 2: SALE_INFO backfill + Gate 4 for counties with missing snapshots ==="
    for county in jefferson boulder broomfield; do
      echo "--- SALE_INFO backfill: $county ---"
      flock -n /tmp/vf_ingest.lock python3 -m verifuse_v2.ingest.ingest_runner --sale-info-backfill --county "$county" --limit 600 || echo "WARN: could not acquire lock for $county"
      echo "--- Gate 4: $county ---"
      python3 -c "
import sys, os; sys.path.insert(0, os.getcwd())
from verifuse_v2.ingest.govsoft_extract import run_extraction_batch
results = run_extraction_batch('$county', limit=600)
print(results)
"
    done

    echo "=== Gate 4 Run Complete ==="
    python3 -c "
import sqlite3, os
conn = sqlite3.connect(os.environ['VERIFUSE_DB_PATH'])
for row in conn.execute('SELECT county, data_grade, COUNT(*) FROM leads GROUP BY county, data_grade ORDER BY county, data_grade'):
    print(row)
conn.close()
"
    ;;

  deploy)
    echo "[vf deploy] Gate 9 deployment sequence. Run each step manually and verify:"
    echo ""
    echo "  1. vf backup-db"
    echo "  2. vf migrate"
    echo "  3. vf api-restart"
    echo "  4. systemctl enable --now verifuse-scrapers.timer"
    echo "  5. vf gauntlet       # must be >= 60 PASS"
    echo "  6. vf rebuild-frontend"
    echo ""
    echo "Manual approval required before each step. See docs/RUNBOOK.md."
    ;;

  *)
    cat <<'USAGE'
VeriFuse one-command ops wrapper

Usage: vf COMMAND [args...]

Required commands:
  migrate                 Run all DB migrations (idempotent)
  seed-counties           Seed county_profiles from counties.yaml (INSERT OR IGNORE)
  gauntlet                Run full smoke gauntlet (target: >= 60 PASS)
  api-start               Start verifuse-api systemd unit
  api-stop                Stop verifuse-api systemd unit
  api-restart             Restart verifuse-api (apply API changes)
  logs-api                Tail API logs (journalctl -f)
  logs-scraper            Tail scraper logs (journalctl -f)
  scraper-run-single      Run single-case ingest (flock; pass --county --case-number)
  scraper-run-window      Run date-window ingest (flock; pass --county --days N)
  scraper-enum            Sequential case enumerator (flock; --county --prefix --start-num --end-num)
  extract-batch           Gate 4 batch extraction on BRONZE leads (--county --limit)
  gate4-run-all           Full Gate 4 pipeline: Phase 1 (adams/weld/douglas/gilpin/arapahoe/denver) + Phase 2 (jefferson/boulder/broomfield with SALE_INFO backfill)
  pending-sales           Scrape Active/Pending pre-sale cases (--county or --all-counties)
  sale-info-backfill      Re-scrape BRONZE leads missing SALE_INFO (--county --limit)
  denver-scrape           Denver Public Trustee PDF scraper (--dry-run to preview)
  promote-eligible        Promote SILVER → GOLD when 6-month restriction expires (--dry-run)
  status                  Show API + scraper timer systemd status
  backup-db               SQLite online backup (timestamped .bak file)

Optional commands:
  db-shell                Open SQLite shell on the DB
  tail-ingest             Alias for logs-scraper
  rebuild-frontend        npm ci + npm run build in verifuse/site/app
  deploy                  Print Gate 9 deploy checklist (manual confirmation required)

Examples:
  vf migrate
  vf gauntlet
  vf scraper-run-single --county jefferson --case-number J2400300
  vf scraper-run-window --county jefferson --days 3
  vf backup-db && vf migrate && vf api-restart && vf gauntlet
USAGE
    exit 1
    ;;
esac
